# ---------------------------------------------------------------------------
# AI Agent Marketplace — backend environment template
#
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# Postgres (matches docker-compose.yml; host port 5433 to avoid conflict with
# any Homebrew postgres typically running on 5432)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/agent_marketplace

# Redis (event bus + rate-limiter state)
REDIS_URL=redis://localhost:6379/0

# Google Gemini API
#   Get a key at https://aistudio.google.com/apikey
#   The free tier is enough for ~50 demo runs; a billing-enabled key avoids
#   503 "model overloaded" spikes during a live demo.
GEMINI_API_KEY=your_gemini_api_key_here

# Models (defaults shown — flash is fastest + most reliable for live demos)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Misc
DEBUG=true
APP_PORT=8000
