# Frontend currently hardcodes the backend URL in lib/api.ts and lib/store.ts.
# For the hackathon demo this is fine (single-host development).
# If you ever deploy frontend and backend on different hosts, refactor those
# two files to read from NEXT_PUBLIC_API_BASE / NEXT_PUBLIC_WS_BASE below.

NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE=ws://localhost:8000
